
import math
import rclpy
from rclpy.node import Node
from sensor_msgs.msg import LaserScan

class Scantest(Node):
    def __init__(self):
        super().__init('scantest')
        self.create_subscription(LaserScan,'/scan',self.scancb,10)

    def scancb(self,msg):
        r = msg.ranges[:]
        l = self.get_logger()
        for ri in range(len(r)):
            if not math.isnan(r[ri]) and r[ri] < 0.5:
                l.info(str(ri) + " " + str(r[ri]))

